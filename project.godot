[layer_names]

3d_render/layer_1="global_visibility"
3d_render/layer_2="monster_visibility"
3d_render/layer_3="human_visibility"
3d_physics/layer_1="ground"
3d_physics/layer_2="wall"
3d_physics/layer_3="environment_object"
3d_physics/layer_4="monster_vision_environment_object"

[physics]

3d/physics_engine="Jolt Physics"
common/physics_interpolation=true

[rendering]

rendering_device/driver.windows="d3d12"
anti_aliasing/quality/use_debanding=true
anti_aliasing/quality/screen_space_aa=2
